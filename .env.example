# ---------------------------------------------------------------------------
# The platform runs fully WITHOUT any of these (local-only mode using
# localStorage). Configure them to enable accounts, multi-user groups, and
# synced progress via PostgreSQL + NextAuth.
# ---------------------------------------------------------------------------

# PostgreSQL connection string (Prisma).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/mbti?schema=public"

# NextAuth — required when auth is enabled.
NEXTAUTH_URL="http://localhost:3000"
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me"

# Google OAuth (optional provider).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Passwordless email login (optional provider). SMTP connection string + from.
# e.g. "smtp://user:pass@smtp.example.com:587"
EMAIL_SERVER=""
EMAIL_FROM="Insight <no-reply@example.com>"
